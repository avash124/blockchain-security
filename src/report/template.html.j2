<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forensic Report: {{ scenario.name }}</title>
    <link rel="stylesheet" href="assets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
</head>
<body>
    <header>
        <h1>Blockchain Exploit Forensic Report</h1>
        <h2>{{ scenario.name }}</h2>
        <div class="meta">
            <span class="date">Date: {{ scenario.date }}</span>
            <span class="verdict verdict-{{ verdict.verdict | lower }}">
                {{ verdict.verdict }}
            </span>
            <span class="confidence">Confidence: {{ "%.1f" | format(verdict.confidence * 100) }}%</span>
        </div>
    </header>

    <section id="summary">
        <h3>Executive Summary</h3>
        <table>
            <tr><td>Technique</td><td>{{ verdict.technique }}</td></tr>
            <tr><td>Transaction</td><td><code>{{ scenario.tx_hash }}</code></td></tr>
            <tr><td>Attacker</td><td><code>{{ scenario.attacker_address }}</code></td></tr>
            <tr><td>Estimated Loss</td><td>${{ scenario.estimated_loss_usd | default("N/A") }}</td></tr>
            <tr><td>Fork Block</td><td>{{ scenario.fork_block }}</td></tr>
        </table>
    </section>

    <section id="flow">
        <h3>Exploit Flow</h3>
        <div class="mermaid">
            {{ mermaid }}
        </div>
    </section>

    <section id="actions">
        <h3>Semantic Actions</h3>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Type</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Depth</th>
                </tr>
            </thead>
            <tbody>
                {% for action in actions %}
                <tr>
                    <td>{{ action.id }}</td>
                    <td>{{ action.type }}</td>
                    <td><code>{{ action.from }}</code></td>
                    <td><code>{{ action.to }}</code></td>
                    <td>{{ action.depth }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section id="predicates">
        <h3>Predicate Results</h3>
        <table>
            <thead>
                <tr><th>Predicate</th><th>Result</th><th>Details</th></tr>
            </thead>
            <tbody>
                {% for p in verdict.predicates %}
                <tr class="predicate-{{ p.result | lower }}">
                    <td>{{ p.name }}</td>
                    <td>{{ p.result }}</td>
                    <td>{{ p.details }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section id="ablation">
        <h3>Ablation Results</h3>
        <table>
            <thead>
                <tr><th>Factor Removed</th><th>Outcome</th><th>Details</th></tr>
            </thead>
            <tbody>
                {% for a in verdict.ablations %}
                <tr>
                    <td>{{ a.factor }}</td>
                    <td>{{ a.outcome }}</td>
                    <td>{{ a.details }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section id="reasoning">
        <h3>Analysis</h3>
        <p>{{ verdict.reasoning }}</p>
    </section>

    <footer>
        <p>Generated by Chain Forensics</p>
    </footer>

    <script>mermaid.initialize({startOnLoad: true, theme: 'dark'});</script>
</body>
</html>
